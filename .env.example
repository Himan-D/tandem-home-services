# Lumina Home — Environment Configuration
# Copy to .env and fill in values

# --- Server ---
PORT=3005
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Database (PostgreSQL only) ---
DATABASE_URL=postgresql://lumina:lumina@localhost:5432/lumina
DB_SCHEMA=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- OSRM (road routing) ---
OSRM_URL=http://localhost:5000

# --- ML Service ---
ML_SERVICE_URL=http://localhost:8000

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# --- Rider Assignment ---
RIDER_AVG_SPEED_KPH=20
RIDER_MAX_CONCURRENT=3
RIDER_SEARCH_RADIUS_KM=5

# --- Dark Store ---
DARK_STORE_SEARCH_RADIUS_KM=10

# --- Rate Limiting ---
RATE_LIMIT_AUTH_PER_MIN=5
RATE_LIMIT_API_PER_MIN=100
RATE_LIMIT_ORDER_PER_MIN=30

# --- Logging ---
LOG_LEVEL=info

# --- Google Maps APIs ---
GOOGLE_MAPS_API_KEY=
# Roads API, Geocoding, Distance Matrix, Places Autocomplete, Directions

# --- GPS Quality / Tracking ---
GPS_MIN_ACCURACY_M=50
GPS_MAX_SPEED_KPH=200
GPS_SNAP_INTERVAL_MS=10000
GPS_SNAP_BATCH_SIZE=100
GPS_KALMAN_PROCESS_NOISE=3
GPS_KALMAN_MEASUREMENT_NOISE=10

# --- Geofence / Arrival ---
GEOFENCE_RADIUS_M=75
GEOFENCE_EXIT_RADIUS_M=120
GEOFENCE_DWELL_SEC=30
GEOFENCE_APPROACHING_M=500

# --- Shifts ---
SHIFTS_AUTO_OFFLINE_CRON=*/5 * * * *

# --- Service Areas ---
SERVICE_AREA_DEFAULT_PRICE_ZONE=1.0

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tandem.app

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Stripe Payments ---
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AI Assistant (OpenRouter) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Web Push (VAPID) ---
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@tandem.app

# --- Stripe Publishable Key (frontend) ---
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_VAPID_PUBLIC_KEY=
